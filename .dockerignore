# Git (root and nested, e.g. clusterio/.git — never needed in the image,
# and clusterio/.git carries the full fork history into custom-target builds)
.git
**/.git
.gitignore
.gitattributes
.github

# Dependency dirs — the custom builder runs `pnpm install` to regenerate these,
# so shipping a local copy only bloats the build context.
**/node_modules

# IDE / Editor
.vscode
.idea
.claude
*.swp
*.swo

# Documentation (not needed in image)
README.md
CLAUDE.md
LICENSE
docs/

# Seed data (mounted at runtime, not baked into image)
seed-data/

# Development tools
tools/
*.ps1

# Runtime data (should not be in build context)
data/
logs/
*.log

# Environment files
.env
.env.example

# OS files
.DS_Store
Thumbs.db

# Temporary files
*.tmp
*.bak

# Clusterio source (uncomment to exclude from build context when using release target)
# clusterio/

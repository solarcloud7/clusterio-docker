# Controller
INIT_CLUSTERIO_ADMIN=
# CONTROLLER_HTTP_PORT=8080
# CONTROLLER_PUBLIC_ADDRESS=
# HOST_COUNT=0
# DEFAULT_MOD_PACK=Space Age 2.0
# DEFAULT_FACTORIO_VERSION=2.0
# Note: If DEFAULT_MOD_PACK contains "Space Age", DLC mods (space-age,
# elevated-rails, quality) are automatically enabled when the pack is created.

# Host
# CONTROLLER_URL=http://clusterio-controller:8080/
# CLUSTERIO_HOST_TOKEN=
# SKIP_CLIENT=false

# Factorio Account (enables runtime game client download on hosts)
# The game client provides graphical asset data for Clusterio's export-data flow.
# On first host startup, if credentials are set and SKIP_CLIENT is not true, the
# client is downloaded once and stored in the data volume (persists across restarts).
# Get your token from https://factorio.com/profile
# FACTORIO_USERNAME=
# FACTORIO_TOKEN=

# Client build type for runtime download: "expansion" (Space Age, default) or "alpha" (base only)
# FACTORIO_CLIENT_BUILD=expansion
# FACTORIO_CLIENT_TAG=stable

# Build target: "custom" (local source in clusterio/) or "release" (npm registry)
# CLUSTERIO_TARGET=custom



# Image selection: which prebuilt GHCR tag `docker compose up` pulls.
# For production pin the immutable pair tag, e.g.:
#   CLUSTERIO_IMAGE_TAG=factorio-2.1.8-clusterio-2.0.0-alpha.26
# CLUSTERIO_IMAGE_TAG=factorio-2.1.8

# Source builds only (docker-compose.dev.yml overlay): release = npm, custom = ./clusterio fork
# CLUSTERIO_TARGET=release

# Mirror plugin logger output (on-disk cluster/host logs) to `docker logs` ([cluster-log] prefix)
# CLUSTERIO_LOG_TO_STDOUT=true

# Multi-cluster machines (docs/multi-cluster.md): give each cluster its own
# host-side ports and its own client volume. `external` volume names are GLOBAL
# to the Docker host — two clusters sharing one client volume clobber each other.
# HOST1_PORTS=34100-34109
# HOST2_PORTS=34200-34209
# FACTORIO_CLIENT_VOLUME=factorio-client

# Controller
INIT_CLUSTERIO_ADMIN=
# CONTROLLER_HTTP_PORT=8080
# CONTROLLER_PUBLIC_ADDRESS=
# HOST_COUNT=0
# DEFAULT_MOD_PACK=Space Age 2.1
# DEFAULT_FACTORIO_VERSION=2.1
# Note: If DEFAULT_MOD_PACK contains "Space Age", DLC mods (space-age,
# elevated-rails, quality, recycler) are automatically enabled when the pack is
# created. recycler is required: space-age + quality hard-depend on it in 2.1.x.

# Export data: which host has the full game client for graphical asset export.
# Set to the host ID (e.g. 1 for clusterio-host-1). Set to 0 or empty to skip.
# EXPORT_HOST=1

# Host
# CONTROLLER_URL=http://clusterio-controller:8080/
# CLUSTERIO_HOST_TOKEN=
# SKIP_CLIENT=false

# Factorio Account (enables runtime game client download on hosts)
# The game client provides graphical asset data for Clusterio's export-data flow.
# On first host startup, if credentials are set and SKIP_CLIENT is not true, the
# client is downloaded once and stored in the data volume (persists across restarts).
# Get your token from https://factorio.com/profile
# FACTORIO_USERNAME=
# FACTORIO_TOKEN=

# Client build type for runtime download: "expansion" (Space Age, default) or "alpha" (base only)
# FACTORIO_CLIENT_BUILD=expansion
# FACTORIO_CLIENT_TAG=stable

# Build target: "custom" (local source in clusterio/) or "release" (npm registry)
# CLUSTERIO_TARGET=custom


